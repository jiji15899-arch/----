# 저장 위치: /.gitignore

# 의존성
node_modules/
.pnp
.pnp.js

# 빌드 결과물
dist/
dist-ssr/
build/
.output/

# 환경변수 (절대 커밋하지 마세요!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# 에디터
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# 로그
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 테스트
coverage/
.nyc_output/

# TypeScript
*.tsbuildinfo

# Vite
.vite/

# Supabase 로컬 개발
.supabase/
supabase/.branches/
supabase/.temp/

# 임시 파일
*.tmp
*.temp
.cache/